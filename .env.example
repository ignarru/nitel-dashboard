# ── BASE DE DATOS ─────────────────────────────────────────
# Si Postgres corre EN EL HOST del VPS (no en contenedor) -> host.docker.internal
# Si Postgres corre en OTRO CONTENEDOR Docker en la misma red -> nombre del contenedor
# Escapar caracteres especiales del password con URL-encoding (@ = %40, etc.)
DATABASE_URL=postgresql://usuario:password@host.docker.internal:5432/iabyia

# ── n8n ───────────────────────────────────────────────────
N8N_WEBHOOK_BUSCAR_LEADS=https://n8n.nitel.com/webhook/nitel-dashboard

# ── GMAIL — Service Account (recomendada en produccion) ──
GOOGLE_SA_JSON=./secrets/sa-key.json
IMPERSONATE_EMAIL=clientes@nitel.com.ar

# ── GMAIL — Alternativa OAuth (si no hay Service Account) ─
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URI=https://dashboard.nitel.com.ar/api/auth/google/callback

# ── REMITENTE ─────────────────────────────────────────────
FROM_EMAIL=clientes@nitel.com.ar
FROM_NAME=Nitel

# ── GENERAL ───────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=https://dashboard.nitel.com.ar

# ── MODO PRUEBA — DEJAR VACIO EN PRODUCCION ───────────────
TEST_EMAIL_OVERRIDE=
